{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "siri3dcad-mcp",
      "version": "0.1.0",
      "title": "Siri3DCAD Studio"
    },
    "tools": [
      {
        "name": "list_models",
        "title": "List Siri3DCAD models",
        "description": "List public 3D models published by Siri3DCAD Studio on Cults3D. Returns name, slug, description, price, tags, thumbnail, and the Cults3D URL for purchase.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25,
              "description": "Maximum number of models to return (1-100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_model",
        "title": "Get model details",
        "description": "Fetch full details for a single Siri3DCAD model by its Cults3D slug, including gallery images, tags, price, and purchase URL.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255,
              "description": "The Cults3D slug of the model (from list_models)."
            }
          },
          "required": [
            "slug"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
